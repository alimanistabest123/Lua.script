    Callback = function()
        local PlayerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
        local function removeNotifications()
            local react = PlayerGui:FindFirstChild("ReactContainer")
            if react then
                local notifs = react:FindFirstChild("Notifications")
                if notifs then
                    notifs:Destroy()
                end
            end
        end
        PlayerGui.ChildAdded:Connect(function(child)
            if child.Name == "ReactContainer" then
                task.delay(0.1, removeNotifications)
            end
        end)
        if PlayerGui:FindFirstChild("ReactContainer") then
            local react = PlayerGui.ReactContainer
            react.ChildAdded:Connect(function(child)
                if child.Name == "Notifications" then
                    task.delay(0.05, removeNotifications)
                end
            end)
        end
        while true do
            removeNotifications()
            task.wait(2)
        end
    end
})

